{
  "$schema": "https://opencode.ai/config.json",
  "model": "llama-cpp/Olmo7B",
  "disabled_providers": [],
  "provider": {
    "llama-cpp": {
      "name": "llama-cpp",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "Olmo7B": {
          "name": "Olmo7B"
        }
      }
    }
  },
  "agent": {
    "architect": {
      "description": "Define a plan to build robust software",
      "mode": "primary",
      "temperature": 0,
      "model": "llama-cpp/Olmo7B",
      "prompt": "{file:./system_prompt/architect.md}",
      "tools": {
        "write": false,
        "edit": false, 
        "bash": false
      }
    }
  },
  "mcp": {
    "4Site": {
      "type": "remote",
      "url": "https://4site.duckdns.org/mcp",
      "enabled": true
    }
  }
}
